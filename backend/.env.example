# Replace this with your own MongoDB Atlas connection string.
# Example:
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/mern_item_manager?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_connection_string

# Local backend port. Railway/Render will provide PORT automatically after deployment.
PORT=5000

# Optional after frontend deployment. Example: https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5173
